import random
palabras_aleatorias=('computadora','xbox','encebollado','hornado','ceviche')
palabra_secreta=random.choice(palabras_aleatorias)
cadena="_"*len(palabra_secreta)
print("Bienvenido al juego del ahorcado")
intentos=0
while True:
    print(cadena) 
    letra=input("Ingresa una letra: ")
    if letra in palabra_secreta:
        for i in range (len(palabra_secreta)):
            if palabra_secreta[i]==letra:
                cadena = cadena[:i] + letra + cadena[i+1:]
    else :
        intentos+=1
        if intentos==1:
            print(" 0")
        elif intentos==2:
            print(" 0")
            print("/")
        elif intentos==3:
            print(" 0")
            print("/|")
        elif intentos==4:
            print(" 0")
            print("/|\\")
        elif intentos==4:
            print(" 0")
            print("/|\\")
            print("/")
        elif intentos==6:
            print(" 0")
            print("/|\\")
            print("/ \\")        
            print(f"Has perdido el juego,la palabra era {palabra_secreta}")
            break
    if  cadena==palabra_secreta:
        print(f"Felicidades has ganado,la palabra era {palabra_secreta} ")
        break